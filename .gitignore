# Local-only — never commit

# Parent workspace private memory
memory/

# OS / editor
.DS_Store
.idea/
.vscode/

# Env / secrets
.env
.env.local
.env.*.local
!.env.example

# Scratch
scratch/
tmp/

# Python venv
.venv/

# Evidence raw dumps with PII risk (review before any commit)
**/evidence/raw/

# --- Node / TypeScript app (app/) ---

# Dependencies
node_modules/
.pnp/
.pnp.js

# Build output
dist/
build/
*.tsbuildinfo

# Vite
.vite/
app/web/dist/

# Test / coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime-generated stores (policy store, audit log, sessions) — never commit live data
data/
**/data/policy-store/
**/data/audit/
**/*.audit.jsonl
