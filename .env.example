# Trust Flow local secrets — copy to .env and fill in (never commit .env).
#
# Loaded automatically when you run the app or `npm run smoke` from app/
# (backend walks up to this repo-root .env).

# --- Apify (evidence scripts) -----------------------------------------------
# https://console.apify.com/account/integrations
APIFY_TOKEN=your_apify_api_token_here

# --- Qwen / DashScope (live boardroom — optional) -----------------------------
# Pay-as-you-go key from Model Studio → API Keys:
# https://modelstudio.console.alibabacloud.com/?tab=app#/api-key
DASHSCOPE_API_KEY=sk-your-dashscope-key-here

# International (Singapore) endpoint — required for the 90-day free token grant.
# Do not switch to the China or US endpoints if you want free-quota models.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Named models — both have separate 1M free grants on intl (90 days).
QWEN_MODEL_DEV=qwen-flash
QWEN_MODEL_DEMO=qwen-max

# Active model (defaults to QWEN_MODEL_DEV). Flip to qwen-max when demo is frozen.
QWEN_MODEL=qwen-flash

# Or keep QWEN_MODEL=qwen-flash and use npm run dev:demo / smoke:demo (sets QWEN_PROFILE=demo).
# npm run dev:demo also sets REPLAY_TURN_DELAY_MS=1000 so recorded boardroom paces ~1s/turn on camera.
# Override: REPLAY_TURN_DELAY_MS=0 (instant, tests) or 1500 (slower theater).
